# Copy to `.env` (gitignored) for local development on your machine/phone.
# Restart `expo start` after changing env vars.

# Personal-phone MVP (no proxy): Gemini API key is bundled into the client build.
EXPO_PUBLIC_GEMINI_API_KEY=
# Optional override (defaults to gemini-1.5-flash)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-1.5-flash

# Optional: recommended for production-ish setups (keeps provider keys server-side)
# EXPO_PUBLIC_SCORECARD_LLM_PROXY_URL=
